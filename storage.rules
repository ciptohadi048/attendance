rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Attendance selfies: /attendance/{userId}/{filename}
    // Only the owning user can upload/read their own selfie.
    // Admins can read any selfie (for the admin dashboard).
    match /attendance/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024  // 5 MB max
        && request.resource.contentType.matches('image/.*');
    }
  }
}
